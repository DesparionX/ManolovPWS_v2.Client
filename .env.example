# Backend API base URL (see docs-for-claude/API-CLIENT.md)
# Local: your locally-running .NET API (e.g. http://localhost:5000)
# Production: set this in Vercel/Netlify's dashboard instead, pointing to the deployed API
VITE_API_BASE_URL=

# Cloudinary (see docs-for-claude/FILE-UPLOAD.md)
# Not secret — unsigned upload preset, safe to be visible in the client bundle
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
